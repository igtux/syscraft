generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("user") // admin, user
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs  AuditLog[]
  hostGroups UserHostGroup[]
}

model UserHostGroup {
  id      Int @id @default(autoincrement())
  userId  Int
  groupId Int

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group HostGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model DataSource {
  id                Int      @id @default(autoincrement())
  name              String   @unique  // human label: "Red Hat Satellite", "Checkmk Prod"
  adapter           String   // adapter key: satellite, checkmk, dns, vcsa, netbox ...
  config            Json     @default("{}")  // connection config: url, user, password, etc.
  enabled           Boolean  @default(true)
  syncIntervalMin   Int      @default(15)
  capabilities      String[] @default([])  // what it provides: hosts, monitoring, dns, vms
  lastSyncAt        DateTime?
  lastSyncStatus    String   @default("never") // never, success, failure, partial
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hostSources HostSource[]
  syncLogs    SyncLog[]
}

model Host {
  id              Int      @id @default(autoincrement())
  fqdn            String   @unique
  ip              String   @default("")
  os              String   @default("")
  arch            String   @default("")
  status          String   @default("new") // active, partial, stale, new, decommissioning
  complianceScore Float    @default(0)
  osCategory      String   @default("unknown") // linux, windows, appliance, unknown
  lastPingAt      DateTime?
  lastPingSuccess Boolean  @default(false)
  macAddress      String   @default("")
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sources          HostSource[]
  agentStatuses    AgentStatus[]
  groupMemberships HostGroupMember[]
  recommendations  Recommendation[]
  events           HostEvent[]
}

model HostSource {
  id             Int      @id @default(autoincrement())
  hostFqdn       String
  dataSourceId   Int
  sourceId       String   @default("")  // external ID in that system
  rawData        Json     @default("{}")
  normalizedData Json     @default("{}")  // common shape: { ip, os, mac, status, lastCheckin, ... }
  lastSynced     DateTime @default(now())

  host       Host       @relation(fields: [hostFqdn], references: [fqdn], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([hostFqdn, dataSourceId])
  @@index([dataSourceId])
}

model AgentBaseline {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  packageName      String
  description      String   @default("")
  requiredForGroups String  @default("[\"all\"]")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AgentStatus {
  id          Int      @id @default(autoincrement())
  hostFqdn    String
  agentName   String
  installed   Boolean  @default(false)
  running     Boolean  @default(false)
  version     String?
  lastChecked DateTime @default(now())

  host Host @relation(fields: [hostFqdn], references: [fqdn], onDelete: Cascade)

  @@unique([hostFqdn, agentName])
}

model SyncLog {
  id           Int       @id @default(autoincrement())
  dataSourceId Int?
  source       String    // kept for backward compat display
  status       String    // success, failure, partial, running
  hostsFound   Int       @default(0)
  hostsUpdated Int       @default(0)
  errors       Json      @default("[]")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  dataSource DataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  target    String   @default("")
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Setting {
  id          Int    @id @default(autoincrement())
  key         String @unique
  value       String
  description String @default("")
}

model Recommendation {
  id            Int      @id @default(autoincrement())
  hostFqdn      String
  type          String
  severity      String
  description   String
  systemTarget  String
  commands      Json     @default("[]")
  status        String   @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  host Host @relation(fields: [hostFqdn], references: [fqdn], onDelete: Cascade)

  @@index([hostFqdn])
  @@index([type])
  @@index([status])
  @@index([severity])
}

model HostGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @default("")
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members HostGroupMember[]
  users   UserHostGroup[]
}

model HostGroupMember {
  id        Int    @id @default(autoincrement())
  groupId   Int
  hostFqdn  String

  group HostGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  host  Host      @relation(fields: [hostFqdn], references: [fqdn], onDelete: Cascade)

  @@unique([groupId, hostFqdn])
}

model HostEvent {
  id        Int      @id @default(autoincrement())
  hostFqdn  String
  event     String
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  host Host @relation(fields: [hostFqdn], references: [fqdn], onDelete: Cascade)

  @@index([hostFqdn])
  @@index([createdAt])
}

model Webhook {
  id            Int       @id @default(autoincrement())
  name          String
  url           String
  secret        String    @default("")
  enabled       Boolean   @default(true)
  events        String[]  @default([])
  headers       Json      @default("{}")
  method        String    @default("POST")
  bodyTemplate  String    @default("")
  retryCount    Int       @default(3)
  retryDelayMs  Int       @default(5000)
  lastFiredAt   DateTime?
  lastStatus    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  logs WebhookLog[]
}

model WebhookLog {
  id         Int      @id @default(autoincrement())
  webhookId  Int
  event      String
  payload    Json
  statusCode Int?
  response   String   @default("")
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}
